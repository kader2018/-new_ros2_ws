<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="asterassembly_ros2_control" params="name initial_positions_file">
        <xacro:property name="initial_positions" value="${xacro.load_yaml(initial_positions_file)['initial_positions']}"/>

        <ros2_control name="${name}" type="system">
            <hardware>
                <!-- Fake hardware for MoveIt2/RViz only. Real Arduino control stays outside this config. -->
                <plugin>mock_components/GenericSystem</plugin>
            </hardware>
            <joint name="bras_droit_de_ar_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['bras_droit_de_ar_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="bras_droit_h_b_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['bras_droit_h_b_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="bras_droit_rot_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['bras_droit_rot_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="bras_droit_coud_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['bras_droit_coud_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="bras_gauche_de_ar_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['bras_gauche_de_ar_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="bras_gauche_h_b_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['bras_gauche_h_b_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="bras_gauche_rot_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['bras_gauche_rot_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="bras_gauche_coude_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['bras_gauche_coude_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="tete_g_d_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['tete_g_d_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="tete_h_b_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['tete_h_b_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="cuisse_droit_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['cuisse_droit_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="genou_droit_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['genou_droit_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="cheville_droite_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['cheville_droite_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="cuisse_gauche_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['cuisse_gauche_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="genou_gauche_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['genou_gauche_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="cheville_gauche_joint">
                <command_interface name="position"/>
                <state_interface name="position">
                    <param name="initial_value">${initial_positions['cheville_gauche_joint']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
        </ros2_control>
    </xacro:macro>
</robot>
